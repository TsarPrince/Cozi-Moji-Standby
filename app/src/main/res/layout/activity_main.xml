<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050507">

    <!-- DIGIT LAYERS (FULL SCREEN) -->
    <FrameLayout android:id="@+id/h1" android:layout_width="match_parent" android:layout_height="match_parent"/>
    <FrameLayout android:id="@+id/h2" android:layout_width="match_parent" android:layout_height="match_parent"/>

    <FrameLayout android:id="@+id/m1" android:layout_width="match_parent" android:layout_height="match_parent"/>
    <FrameLayout android:id="@+id/m2" android:layout_width="match_parent" android:layout_height="match_parent"/>

    <FrameLayout android:id="@+id/s1" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone"/>
    <FrameLayout android:id="@+id/s2" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone"/>

    <!-- COLONS -->
    <TextView
        android:id="@+id/colon1"
        android:text=":"
        android:textSize="220sp"
        android:textColor="#BBFFFFFF"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:includeFontPadding="false"
        android:textStyle="bold"
        android:alpha="0.7"/>

    <TextView
        android:id="@+id/colon2"
        android:text=":"
        android:textSize="220sp"
        android:textColor="#BBFFFFFF"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:includeFontPadding="false"
        android:textStyle="bold"
        android:alpha="0.7"/>

    <!-- Debug Log View -->
    <ScrollView
        android:id="@+id/debugScroll"
        android:layout_width="300dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:background="#88000000"
        android:padding="8dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/debugLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF00"
            android:textSize="10sp"
            android:typeface="monospace" />
    </ScrollView>

</FrameLayout>